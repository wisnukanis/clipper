LOCAL_PORT=8788
APP_TIMEZONE=Asia/Jakarta
PUBLIC_BASE_URL=https://www.example.com/ig-generated
UPLOAD_DRIVER=ftp

DRY_RUN=true
AUTO_PUBLISH=false
CLEANUP_LOCAL_AFTER_PUBLISH=false
AUTO_DASHBOARD_PIN=
AUTO_DASHBOARD_ALLOW_REMOTE=false

POST_CRON=7 5 * * *
DEFAULT_THEME=auto

GRAPH_API_VERSION=v21.0

# Instagram Reels via Instagram Graph API
INSTAGRAM_UPLOAD_ENABLED=true
INSTAGRAM_IG_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# Facebook Page/Reels via Meta Graph API
FACEBOOK_UPLOAD_ENABLED=true
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_MEDIA_TYPE=reel
FACEBOOK_VIDEO_STATE=PUBLISHED
FACEBOOK_TITLE_PREFIX=

META_APP_ID=
META_APP_SECRET=
AUTO_REFRESH_INSTAGRAM_TOKEN=true
TOKEN_REFRESH_BEFORE_DAYS=10

# YouTube Shorts upload via YouTube Data API OAuth 2.0
# Jangan isi dengan client secret yang pernah terlanjur dibagikan. Buat/rotate secret baru.
YOUTUBE_UPLOAD_ENABLED=true
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_PRIVACY_STATUS=public
YOUTUBE_CATEGORY_ID=22
YOUTUBE_TAGS=podcast,shorts,indonesia
YOUTUBE_TITLE_PREFIX=
YOUTUBE_DESCRIPTION_FOOTER=

FTP_HOST=
FTP_PORT=21
FTP_USER=
FTP_PASSWORD=
FTP_REMOTE_DIR=/public_html/ig-generated

GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-flash-latest
GEMINI_TEMPERATURE=0.75

PYTHON_CMD=python
CLIPPER_ROOT=clipper
CLIP_COUNT=1
MIN_CLIP_SECONDS=40
MAX_CLIP_SECONDS=60
VIDEO_QUALITY_PROFILE=standard

DEEPGRAM_ENABLED=1
DEEPGRAM_API_KEYS=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=id
DEEPGRAM_TIMEOUT_SECONDS=900

OUTPUT_WIDTH=1080
OUTPUT_HEIGHT=1920
VIDEO_LANGUAGE=id

DOWNLOAD_MAX_HEIGHT=720
DOWNLOAD_COMPRESS_CRF=30
FINAL_RENDER_CRF=27

YTDLP_COOKIES_FILE=
YTDLP_COOKIES_FROM_BROWSER=
YTDLP_JS_RUNTIMES=node
YTDLP_REMOTE_COMPONENTS=ejs:github

SUBTITLE_OFFSET_SECONDS=0
