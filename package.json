{
  "name": "podcast-clipper-automation",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Automation pipeline for YouTube podcast clips, FTP storage, and Instagram Reels publishing.",
  "scripts": {
    "check": "node src/check.js",
    "dashboard": "node src/server.js",
    "dev": "node src/server.js",
    "run": "node src/run.js",
    "dry-run": "node src/run.js --dry-run",
    "publish": "node src/run.js --publish",
    "publish:ready": "node src/publish-ready.js",
    "scheduler": "node src/scheduler.js",
    "youtube:check": "node src/youtube-check.js",
    "instagram:check": "node src/instagram-check.js",
    "instagram:token": "node src/instagram-token-fastcheck.js --persist-local",
    "clipper:setup": "python -m pip install -r clipper/requirements.txt"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "basic-ftp": "^5.3.1",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "node-cron": "^4.2.1"
  }
}
